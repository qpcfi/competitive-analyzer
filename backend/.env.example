DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/competitive_analyzer
LANGGRAPH_CHECKPOINT_URL=postgresql://postgres:password@localhost:5432/competitive_analyzer
CHECKPOINT_DATABASE_URL=postgresql://postgres:password@localhost:5432/competitive_analyzer

LLM_API_KEY=your_openai_compatible_api_key
LLM_BASE_URL=https://your-openai-compatible-endpoint.example/api/v3
LLM_MODEL=your_model_or_endpoint_id
LLM_DISPLAY_NAME=your_model_display_name

# Legacy fallback variables are still supported when LLM_* is unset.
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

TASK_EVENT_REPLAY_LIMIT=100


XIAOHONGSHU_MCP_URL=http://localhost:18060/mcp
XIAOHONGSHU_MCP_TOOL=publish_content
XIAOHONGSHU_MCP_TOKEN=your_xiaohongshu_cookie_or_token_if_required

TENCENT_WJ_API_BASE_URL=https://open.wj.qq.com
TENCENT_WJ_APP_ID=your_tencent_wenjuan_app_id
TENCENT_WJ_SECRET=your_tencent_wenjuan_secret
TENCENT_WJ_ORG=your_tencent_wenjuan_org_id
TENCENT_WJ_USER_ID=your_tencent_wenjuan_user_id
TENCENT_WJ_TOKEN_PATH=/api/oauth2/access_token
TENCENT_WJ_CREATE_SURVEY_PATH=/api/surveys
TENCENT_WJ_RESPONSES_PATH=/api/surveys/{survey_id}/answers
